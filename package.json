{
  "name": "ds-visualizer",
  "private": true,
  "version": "20.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/check-bundle.js",
    "build:analyze": "vite build --mode analyze",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "node scripts/run-e2e.mjs",
    "test:e2e:run": "playwright test e2e --reporter=line",
    "test:e2e:list": "playwright test e2e --list",
    "test:e2e:firefox": "BROWSER=firefox node scripts/run-e2e.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sentry/react": "^10.57.0",
    "d3": "^7.9.0",
    "gifenc": "^1.0.3",
    "jszip": "^3.10.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "~4.11.3",
    "@eslint/js": "~10.0.1",
    "@tailwindcss/vite": "~4.3.0",
    "@testing-library/jest-dom": "~6.9.1",
    "@testing-library/react": "~16.3.2",
    "@types/d3": "~7.4.3",
    "@types/node": "~25.9.3",
    "@types/react": "~19.2.15",
    "@types/react-dom": "~19.2.3",
    "@vitejs/plugin-react": "~6.0.2",
    "@vitest/coverage-v8": "~4.1.7",
    "autoprefixer": "~10.5.0",
    "eslint": "~10.4.0",
    "eslint-plugin-react-hooks": "~7.1.1",
    "eslint-plugin-react-refresh": "~0.5.2",
    "globals": "~17.6.0",
    "jsdom": "~29.1.1",
    "playwright": "~1.60.0",
    "postcss": "~8.5.15",
    "rollup-plugin-visualizer": "~5.14.0",
    "tailwindcss": "~4.3.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "~8.61.1",
    "vite": "~8.0.16",
    "vite-plugin-pwa": "~1.3.0",
    "vitest": "~4.1.7"
  }
}
