// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`arrayVisualizer snapshot > 应渲染出结构稳定的 SVG 标记（3 个元素） 1`] = `"<defs><radialGradient id="grad-node-default"><stop offset="0%" stop-color="#3b82f6"></stop><stop offset="100%" stop-color="#3b82f6"></stop></radialGradient><radialGradient id="grad-node-root"><stop offset="0%" stop-color="#f59e0b"></stop><stop offset="100%" stop-color="#f59e0b"></stop></radialGradient><radialGradient id="grad-node-leaf"><stop offset="0%" stop-color="#10b981"></stop><stop offset="100%" stop-color="#10b981"></stop></radialGradient><radialGradient id="grad-node-active"><stop offset="0%" stop-color="#ef4444"></stop><stop offset="100%" stop-color="#ef4444"></stop></radialGradient><radialGradient id="grad-node-error"><stop offset="0%" stop-color="#dc2626"></stop><stop offset="100%" stop-color="#dc2626"></stop></radialGradient><radialGradient id="grad-bar-default"><stop offset="0%" stop-color="#3b82f6"></stop><stop offset="100%" stop-color="#3b82f6"></stop></radialGradient><radialGradient id="grad-bar-active"><stop offset="0%" stop-color="#ef4444"></stop><stop offset="100%" stop-color="#ef4444"></stop></radialGradient><radialGradient id="grad-bar-compare"><stop offset="0%" stop-color="#ef4444"></stop><stop offset="100%" stop-color="#ef4444"></stop></radialGradient><radialGradient id="grad-bar-swap"><stop offset="0%" stop-color="#8b5cf6"></stop><stop offset="100%" stop-color="#8b5cf6"></stop></radialGradient><radialGradient id="grad-bar-sorted"><stop offset="0%" stop-color="#10b981"></stop><stop offset="100%" stop-color="#10b981"></stop></radialGradient><filter id="array-shadow" x="-20%" y="-20%" width="140%" height="140%"><feDropShadow dx="1" dy="2" stdDeviation="2" flood-opacity="0.15"></feDropShadow></filter></defs><g class="array-item" transform="translate(300, 165)" tabindex="0" role="group" aria-label="Array element [0]: 1"><rect width="60" height="50" rx="8" fill="url(#grad-bar-default)" stroke="#1d4ed8" stroke-width="2" filter="url(#array-shadow)"></rect><text x="30" y="25" dy="0.35em" text-anchor="middle" fill="#ffffff" font-size="16px" font-weight="bold">1</text><text x="30" y="68" text-anchor="middle" fill="#4b5563" font-size="11px" font-weight="600" font-family="var(--font-mono)">[0]</text></g><g class="array-item" transform="translate(370, 165)" tabindex="0" role="group" aria-label="Array element [1]: 2"><rect width="60" height="50" rx="8" fill="url(#grad-bar-default)" stroke="#1d4ed8" stroke-width="2" filter="url(#array-shadow)"></rect><text x="30" y="25" dy="0.35em" text-anchor="middle" fill="#ffffff" font-size="16px" font-weight="bold">2</text><text x="30" y="68" text-anchor="middle" fill="#4b5563" font-size="11px" font-weight="600" font-family="var(--font-mono)">[1]</text></g><g class="array-item" transform="translate(440, 165)" tabindex="0" role="group" aria-label="Array element [2]: 3"><rect width="60" height="50" rx="8" fill="url(#grad-bar-default)" stroke="#1d4ed8" stroke-width="2" filter="url(#array-shadow)"></rect><text x="30" y="25" dy="0.35em" text-anchor="middle" fill="#ffffff" font-size="16px" font-weight="bold">3</text><text x="30" y="68" text-anchor="middle" fill="#4b5563" font-size="11px" font-weight="600" font-family="var(--font-mono)">[2]</text></g>"`;
